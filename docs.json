{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Kulmi Pay",
  "logo": {
    "light": "/logo.png",
    "dark": "/logo.png",
    "href": "https://www.kulmipay.com"
  },
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#F56E0F",
    "light": "#F8923D",
    "dark": "#D45A00"
  },
  "fonts": {
    "heading": {
      "family": "DM Sans",
      "weight": 700
    },
    "body": {
      "family": "DM Sans",
      "weight": 400
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Sign Up",
      "href": "https://app.kulmipay.com"
    },
    "links": [
      {
        "label": "Website",
        "href": "https://www.kulmipay.com"
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/kulmipay",
      "linkedin": "https://www.linkedin.com/company/kulmipay",
      "github": "https://github.com/kulmipay"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication",
              "sandbox"
            ]
          },
          {
            "group": "Collections",
            "pages": [
              "collections/overview",
              "collections/mpesa-stk-push",
              "collections/card-payments",
              "collections/payment-links",
              "collections/checkout"
            ]
          },
          {
            "group": "Disbursements",
            "pages": [
              "disbursements/overview",
              "disbursements/send-money",
              "disbursements/approve-cancel",
              "disbursements/bank-codes"
            ]
          },
          {
            "group": "Wallets",
            "pages": [
              "wallets/overview",
              "wallets/transfers",
              "wallets/forex"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "webhooks/overview",
              "webhooks/events"
            ]
          },
          {
            "group": "More Features",
            "pages": [
              "subscriptions",
              "beneficiaries",
              "troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Collections",
            "pages": [
              "api-reference/collect-payment",
              "api-reference/stk-push",
