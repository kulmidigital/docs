{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Kulmi Pay",
  "logo": {
    "light": "/logo.png",
    "dark": "/logo.png",
    "href": "https://www.kulmipay.com"
  },
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#F56E0F",
    "light": "#F8923D",
    "dark": "#D45A00"
  },
  "fonts": {
    "heading": {
      "family": "DM Sans",
      "weight": 700
    },
    "body": {
      "family": "DM Sans",
      "weight": 400
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Sign Up",
      "href": "https://app.kulmipay.com"
    },
    "links": [
      {
        "label": "Website",
        "href": "https://www.kulmipay.com"
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/kulmipay",
      "linkedin": "https://www.linkedin.com/company/kulmipay",
      "github": "https://github.com/kulmipay"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication",
              "client-libraries",
              "sandbox",
              "troubleshooting"
            ]
          },
          {
            "group": "Collections",
            "pages": [
              "collections/overview",
              "collections/mpesa-stk-push",
              "collections/pesalink-bank-payments",
              "collections/checkout",
              "woocommerce"
            ]
          },
          {
            "group": "Send Money",
            "pages": [
              "send-money/introduction",
              "send-money/mpesa-b2c",
              "send-money/mpesa-b2b",
              "send-money/bank-payouts",
              "send-money/beneficiaries",
              "send-money/transaction-status",
              "send-money/kulmipay-p2p"
            ]
          },
          {
            "group": "Wallet as a Service",
            "pages": [
              "wallets/introduction",
              "wallets/retrieve-wallets",
              "wallets/create-wallets",
              "wallets/wallet-transactions",
              "wallets/fund-wallet",
              "wallets/internal-transfers"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "webhooks/overview",
              "webhooks/setup",
              "webhooks/payment-collection-events",
              "webhooks/send-money-events",
              "webhooks/chargeback-events",
              "webhooks/wallet-intra-transfer-events"
            ]
          },
          {
            "group": "Refunds",
            "pages": [
              "refunds/creating-a-refund",
              "refunds/retrieve-refunds"
            ]
          },
          {
            "group": "SMS Customization",
            "pages": [
              "sms-customization/introduction",
              "sms-customization/payment-collection-sms",
              "sms-customization/payment-disbursement-sms"
            ]
          },
          {
            "group": "Bring Your M-Pesa Till/PayBill Number",
            "pages": [
              "mpesa-paybill/introduction",
              "mpesa-paybill/configuring-your-account"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.yml",
        "groups": [
          {
            "group": "Collections",
            "pages": [
              "POST /payment/collection",
              "POST /payment/mpesa-stk-push",
              "POST /payment/status",
              "POST /checkout",
              "POST /checkout/details"
            ]
          },
          {
            "group": "Send Money",
            "pages": [
              "POST /send-money/initiate",
              "POST /send-money/approve",
              "POST /send-money/cancel",
              "POST /send-money/status",
              "POST /send-money/validate-accounts",
              "GET /send-money/beneficiaries",
              "GET /send-money/beneficiaries/frequently_used",
              "GET /send-money/bank-codes/ke"
            ]
          },
          {
            "group": "Wallet as a Service",
            "pages": [
              "GET /wallets",
              "POST /wallets",
              "GET /wallets/{id}",
              "GET /wallets/{id}/transactions",
              "POST /wallets/{id}/intra_transfer"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "GET /webhooks",
              "GET /webhooks-events"
            ]
          },
          {
            "group": "Refunds",
            "pages": [
              "GET /chargebacks",
              "POST /chargebacks",
              "GET /chargebacks/{id}"
            ]
          },
          {
            "group": "Bring Your M-Pesa Till/PayBill Number",
            "pages": [
              "GET /mpesa-paybill-accounts",
              "POST /mpesa-paybill-accounts",
              "GET /mpesa-paybill-accounts/{id}"
            ]
          }
        ]
      }
    ]
  }
}
